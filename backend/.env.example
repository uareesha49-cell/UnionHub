# Use a `.env` in the project root when running `npm start` / `npm run dev` from the repo root.
PORT=4000
JWT_SECRET=change_me
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/unionhub
# If you use MongoDB Atlas: the same URI can work on Vercel but fail on localhost until you add
# your home/office public IP in Atlas → Network Access (or 0.0.0.0/0 for dev only).
# Vite proxies /api to this port. If you change PORT above, set the same value in root `.env` as
# VITE_DEV_API_PORT=... and restart `npm run dev` (root `.env` PORT alone is not used for the proxy).
