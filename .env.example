# Vercel: add secrets in the project → Settings → Environment Variables, then redeploy.
# Single Vercel app (this repo): `/api` is handled by `api/index.js` — leave empty so the
# browser uses same-origin requests. Set only if the SPA is built for a different API host:
#   VITE_API_ORIGIN=https://your-api.example.com   (no trailing slash)
VITE_API_ORIGIN=

# Local: match backend PORT — see backend/.env.example
# VITE_DEV_API_PORT=4000
